# ── TeenSync Backend Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.

# ── App ─────────────────────────────────────────────────────────────────────────
APP_NAME="TeenSync API"
APP_VERSION="1.0.0"
DEBUG=true
ALLOWED_ORIGINS="http://localhost:3456,http://127.0.0.1:3456,http://localhost:5173"

# ── Database ────────────────────────────────────────────────────────────────────
# For SQLite (default, zero setup):
DATABASE_URL="sqlite+aiosqlite:///./teensync.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/teensync"

# ── JWT Authentication ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="change-me-to-a-long-random-secret-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / LLM Integration (Optional) ─────────────────────────────────────────────
# Leave empty to use rule-based chatbot. Add a key for smarter AI responses.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# ── NLP Settings ────────────────────────────────────────────────────────────────
# Minimum sentiment confidence threshold (0.0 - 1.0)
SENTIMENT_THRESHOLD=0.05

# ── Burnout Detection ───────────────────────────────────────────────────────────
BURNOUT_HIGH_THRESHOLD=65
BURNOUT_MEDIUM_THRESHOLD=35

# ── Peer Support Moderation ─────────────────────────────────────────────────────
# Enable automatic flagging of harmful content
MODERATION_ENABLED=true
